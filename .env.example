# --- Telegram MTProto (userbot listener) ---
# Get from https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Phone of the warmed-up account used for listening
TELEGRAM_PHONE=+7900XXXXXXX

# --- aiogram Bot API ---
# Token from @BotFather
BOT_TOKEN=

# --- Access control ---
# Comma-separated list of Telegram user_id for OWNERs (immutable superadmins).
# OWNERs can manage admins, chats, keywords, settings.
OWNER_IDS=123456789

# --- Database ---
POSTGRES_USER=smk
POSTGRES_PASSWORD=smk
POSTGRES_DB=smk
# DSN used inside the bot container; matches docker-compose service name
POSTGRES_DSN=postgresql+asyncpg://smk:smk@postgres:5432/smk

# --- Paths ---
SESSION_PATH=./data/session
LOG_DIR=./logs
LOG_LEVEL=INFO

# --- Runtime tuning ---
# Receiver chat for leads (can also be set via /setreceiver). Leave empty initially.
RECEIVER_CHAT_ID=
HEARTBEAT_INTERVAL_SEC=900
JOIN_CHAT_DELAY_SEC=25
LEAD_SEND_DELAY_SEC=1.1
